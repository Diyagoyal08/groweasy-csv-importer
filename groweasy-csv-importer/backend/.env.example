# Which AI provider to use: "gemini" (default, recommended - free tier) or "openai"
AI_PROVIDER=gemini

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Only needed if AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# How many CSV rows to send to the AI per request
AI_BATCH_SIZE=25
AI_MAX_RETRIES=2

# Allow your deployed frontend to call this backend. Use * for local dev only.
CORS_ORIGIN=*

PORT=4000
